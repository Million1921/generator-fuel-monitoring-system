generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// 1. Site Management
model Site {
  id              String      @id @default(cuid())
  siteNumber      String      @unique // e.g., AA-01
  location        String
  region          String      // Addis, Oromia, etc.
  tankerCapacity  Float
  generators      Generator[]
  workRequests    WorkRequest[]
}

// 2. Generator Management
model Generator {
  id                String      @id @default(cuid())
  serialNumber      String      @unique
  model             String
  capacityKVA       Float
  stdConsumption    Float       // L/h
  currentRunningHour Float      @default(0)
  siteId            String
  site              Site        @relation(fields: [siteId], references: [id])
}

// 3. Work Request & Delivery Logic
model WorkRequest {
  id                String      @id @default(cuid())
  workOrderNumber   String      @unique // Generated by Fuel Dept
  siteId            String
  site              Site        @relation(fields: [siteId], references: [id])
  priority          Priority    @default(ROUTINE)
  status            Status      @default(PENDING_SUPERVISOR)
  
  // Requester Info
  requestedBy       String      // ETHIO19492
  requesterEmail    String
  requesterPhone    String
  
  // Refueling Logic (Delivery Info)
  begRunningHour    Float?
  endRunningHour    Float?
  totalRunningHour  Float?      // Computed: end - beg
  actualRefueled    Float?      // Liters
  fuelBeforeRefuel  Float?
  unitPrice         Float?      // For "Amount in Birr"
  
  // Security
  guardName         String?
  guardSource       String?
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

enum Priority {
  EMERGENCY
  URGENT
  HIGH
  MEDIUM
  LOW
  ROUTINE
}

enum Status {
  PENDING_SUPERVISOR
  PENDING_MANAGER
  APPROVED_FOR_FUEL
  WORK_ORDER_CREATED
  COMPLETED
}
